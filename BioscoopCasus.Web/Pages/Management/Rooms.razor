@page "/management/rooms"
@attribute [Authorize]
@inject RoomService RoomService
@using BioscoopCasus.Web.Components
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["RoomManagementTitle"]</PageTitle>

<div class="management-container">
    <div class="header-section">
        <a href="/management" class="back-link">
            <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
            @L["Dashboard"]
        </a>
        <div class="title-row">
            <h1>@L["RoomManagementTitle"]</h1>
            <FormButton IsPrimary="true" Text="@L["NewRoom"]" OnClick="OnAddRoomClick" CssClass="add-room-btn" />
        </div>
        <p class="subtitle">@L["RoomsSubtitle"]</p>
    </div>

    @if (IsLoading)
    {
        <div class="loading-state">
            <span class="loading-spinner"></span>
            <p>@L["LoadingRooms"]</p>
        </div>
    }
    else
    {
        <div class="rooms-list">
            @if (!AllRooms.Any())
            {
                <div class="empty-state">@L["NoRoomsConfigured"]</div>
            }
            else
            {
                @foreach (var room in AllRooms)
                {
                    <div class="room-card" @onclick="() => OnRoomClick(room)">
                        <div class="room-icon">
                            <span>@room.Number</span>
                        </div>
                        <div class="room-info">
                            <h3>@room.Name</h3>
                            <div class="room-stats">
                                <span class="stat">@room.Rows.Count @L["RowsLabel"]</span>
                                <span class="stat">@room.Rows.Sum(r => r.SeatCount) @L["SeatsLabel"]</span>
                                @if (room.Has3D)
                                {
                                    <span class="badge badge-3d">3D</span>
                                }
                                @if (room.IsWheelchairAccessible)
                                {
                                    <span class="badge badge-wheelchair">&#9855;</span>
                                }
                            </div>
                        </div>
                        <div class="room-actions">
                            <span class="edit-link">@L["Edit"]</span>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

@if (ShowModal)
{
    <TerminalModal Visible="ShowModal" Title="@(IsCreating ? L["NewRoom"] : L["EditRoom"])" OnClose="CloseModal">
        <ChildContent>
            <div class="room-form">
                <div class="form-row">
                    <TerminalInput Label="@L["RoomNumberLabel"]" Type="number" @bind-Value="RoomNumberString" CssClass="flex-1" />
                    <TerminalInput Label="@L["NameLabel"]" @bind-Value="EditRoom.Name" Placeholder="@L["RoomNamePlaceholder"]" CssClass="flex-2" />
                </div>
                
                <div class="checkbox-row">
                    <label class="checkbox-container">
                        <input type="checkbox" @bind="EditRoom.Has3D" />
                        <span class="checkmark"></span>
                        @L["Supports3D"]
                    </label>
                    <label class="checkbox-container">
                        <input type="checkbox" @bind="EditRoom.IsWheelchairAccessible" />
                        <span class="checkmark"></span>
                        @L["WheelchairAccessible"]
                    </label>
                </div>

                <div class="rows-editor">
                    <div class="editor-header">
                        <h3>@L["RowsAndSeatsTitle"]</h3>
                        <FormButton IsPrimary="false" OnClick="AddRow" CssClass="small-btn">
                            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            @L["AddRow"]
                        </FormButton>
                    </div>
                    
                    <div class="rows-list">
                        @for (int i = 0; i < EditRows.Count; i++)
                        {
                            var index = i;
                            var row = EditRows[i];
                            <div class="row-entry">
                                <span class="row-num">@L["RowLabel", index + 1]</span>
                                <div class="seat-input">
                                    <input type="number" class="terminal-input" @oninput="(e) => row.SeatCount = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" value="@row.SeatCount" />
                                    <span class="label">@L["SeatsLabel"]</span>
                                </div>
                                <button class="remove-row-btn" @onclick="() => RemoveRow(index)">
                                    <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                    </svg>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </ChildContent>
        <Footer>
            @if (!IsCreating)
            {
                <FormButton IsPrimary="false" Text="@L["Delete"]" OnClick="() => ShowConfirmation = true" CssClass="delete-btn" />
            }
            <div style="flex-grow: 1"></div>
            <FormButton IsPrimary="false" Text="@L["Cancel"]" OnClick="CloseModal" />
            <FormButton IsPrimary="true" Text="@(IsCreating ? L["Add"] : L["Save"])" OnClick="HandleSave" />
        </Footer>
    </TerminalModal>
}

<ConfirmationModal Visible="ShowConfirmation" 
                   Title="@L["DeleteRoomTitle"]" 
                   ConfirmText="@L["Delete"]"
                   OnConfirm="HandleDelete" 
                   OnCancel="() => ShowConfirmation = false">
    <ChildContent>
        <p>@L["DeleteRoomConfirm", EditRoom.Name ?? $"{L["RoomLabel"]} {EditRoom.Number}"]</p>
    </ChildContent>
</ConfirmationModal>

<style>
    .management-container {
        max-width: 1000px;
        margin: 2rem auto;
        padding: 0 1.5rem;
    }

    .header-section {
        margin-bottom: 3rem;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--primary-rose);
    }

    .title-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .title-row h1 {
        font-size: 2.5rem;
        margin: 0;
        color: var(--text-high);
    }

    .subtitle {
        color: var(--text-muted);
        font-size: 1.1rem;
    }

    .add-room-btn {
        width: auto !important;
        padding: 0.75rem 1.5rem;
    }

    /* Rooms List */
    .rooms-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .room-card {
        background: var(--surface-glass);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        padding: 1.5rem 2rem;
        display: flex;
        align-items: center;
        gap: 2rem;
        cursor: pointer;
        transition: all 0.2s ease;
        backdrop-filter: blur(10px);
    }

    .room-card:hover {
        border-color: var(--primary-rose);
        background: rgba(255, 255, 255, 0.08);
        transform: translateX(5px);
    }

    .room-icon {
        width: 60px;
        height: 60px;
        background: rgba(225, 29, 72, 0.1);
        border: 2px solid var(--primary-rose);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--primary-rose);
    }

    .room-info {
        flex-grow: 1;
    }

    .room-info h3 {
        margin: 0 0 0.5rem 0;
        font-size: 1.3rem;
        color: var(--text-high);
    }

    .room-stats {
        display: flex;
        align-items: center;
        gap: 1.5rem;
    }

    .stat {
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .badge {
        padding: 0.25rem 0.6rem;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .badge-3d { background: rgba(56, 189, 248, 0.1); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.2); }
    .badge-wheelchair { background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2); }

    .edit-link {
        color: var(--text-muted);
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.2s;
    }

    .room-card:hover .edit-link {
        color: var(--primary-rose);
    }

    /* Form Styles */
    .room-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-row {
        display: flex;
        gap: 1rem;
    }

    .flex-1 { flex: 1; }
    .flex-2 { flex: 2; }

    .checkbox-row {
        display: flex;
        gap: 2rem;
        padding: 0.5rem 0;
    }

    .checkbox-container {
        display: flex;
        align-items: center;
        position: relative;
        padding-left: 35px;
        cursor: pointer;
        font-size: 0.95rem;
        color: var(--text-medium);
        user-select: none;
    }

    .checkbox-container input {
        position: absolute;
        opacity: 0;
        cursor: pointer;
        height: 0;
        width: 0;
    }

    .checkmark {
        position: absolute;
        top: 0;
        left: 0;
        height: 24px;
        width: 24px;
        background-color: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 6px;
    }

    .checkbox-container:hover input ~ .checkmark {
        background-color: rgba(255, 255, 255, 0.15);
    }

    .checkbox-container input:checked ~ .checkmark {
        background-color: var(--primary-rose);
        border-color: var(--primary-rose);
    }

    .checkmark:after {
        content: "";
        position: absolute;
        display: none;
        left: 8px;
        top: 4px;
        width: 5px;
        height: 10px;
        border: solid white;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
    }

    .checkbox-container input:checked ~ .checkmark:after {
        display: block;
    }

    /* Rows Editor */
    .rows-editor {
        background: rgba(0, 0, 0, 0.2);
        border-radius: 12px;
        padding: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.25rem;
    }

    .editor-header h3 {
        margin: 0;
        font-size: 1.1rem;
        color: var(--text-high);
    }

    .small-btn {
        width: auto !important;
        font-size: 0.85rem;
        padding: 0.4rem 0.8rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .rows-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-height: 250px;
        overflow-y: auto;
        padding-right: 0.5rem;
    }

    .row-entry {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        background: rgba(255, 255, 255, 0.03);
        padding: 0.75rem 1rem;
        border-radius: 8px;
    }

    .row-num {
        font-weight: 700;
        color: var(--text-high);
        min-width: 60px;
    }

    .seat-input {
        display: flex;
        align-items: center;
        gap: 1rem;
        flex-grow: 1;
    }

    .seat-input .terminal-input {
        width: 80px;
        text-align: center;
        padding: 0.5rem;
    }

    .seat-input .label {
        font-size: 0.85rem;
        color: var(--text-muted);
    }

    .remove-row-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        cursor: pointer;
        padding: 0.4rem;
        transition: color 0.2s;
    }

    .remove-row-btn:hover {
        color: var(--primary-rose);
    }

    .delete-btn {
        background: rgba(225, 29, 72, 0.05) !important;
        border-color: rgba(225, 29, 72, 0.2) !important;
        color: var(--primary-rose) !important;
    }

    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 5rem 0;
        gap: 1.5rem;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid rgba(255, 255, 255, 0.1);
        border-top-color: var(--primary-rose);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    private List<RoomResponseDto> AllRooms { get; set; } = new();
    private bool IsLoading { get; set; } = true;

    // Modal state
    private bool ShowModal { get; set; }
    private bool ShowConfirmation { get; set; }
    private bool IsCreating { get; set; }
    private RoomResponseDto? SelectedRoom { get; set; }
    
    private RoomForm EditRoom { get; set; } = new();
    private List<RowForm> EditRows { get; set; } = new();

    private class RoomForm
    {
        public int Number { get; set; } = 1;
        public string Name { get; set; } = "";
        public bool Has3D { get; set; }
        public bool IsWheelchairAccessible { get; set; }
    }

    private class RowForm
    {
        public int RowNumber { get; set; }
        public int SeatCount { get; set; } = 10;
    }

    private string RoomNumberString
    {
        get => EditRoom.Number.ToString();
        set => EditRoom.Number = int.TryParse(value, out var v) ? v : 1;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRooms();
    }

    private async Task LoadRooms()
    {
        IsLoading = true;
        try
        {
            AllRooms = (await RoomService.GetRoomsAsync()).ToList();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void OnAddRoomClick()
    {
        IsCreating = true;
        EditRoom = new RoomForm();
        EditRows = new List<RowForm> { new RowForm { RowNumber = 1, SeatCount = 10 } };
        ShowModal = true;
    }

    private void OnRoomClick(RoomResponseDto room)
    {
        IsCreating = false;
        SelectedRoom = room;
        EditRoom = new RoomForm
        {
            Number = room.Number,
            Name = room.Name,
            Has3D = room.Has3D,
            IsWheelchairAccessible = room.IsWheelchairAccessible
        };
        EditRows = room.Rows.Select(r => new RowForm { RowNumber = r.RowNumber, SeatCount = r.SeatCount }).ToList();
        ShowModal = true;
    }

    private void AddRow()
    {
        var nextNum = EditRows.Count + 1;
        EditRows.Add(new RowForm { RowNumber = nextNum, SeatCount = 10 });
    }

    private void RemoveRow(int index)
    {
        EditRows.RemoveAt(index);
        // Re-number rows
        for (int i = 0; i < EditRows.Count; i++)
        {
            EditRows[i].RowNumber = i + 1;
        }
    }

    private void CloseModal()
    {
        ShowModal = false;
        SelectedRoom = null;
    }

    private async Task HandleSave()
    {
        bool success;
        var rowCreateDtos = EditRows.Select(r => new RowCreateDto(r.RowNumber, r.SeatCount)).ToList();
        
        if (IsCreating)
        {
            var createDto = new RoomCreateDto(EditRoom.Number, EditRoom.Name, EditRoom.Has3D, EditRoom.IsWheelchairAccessible, rowCreateDtos);
            success = await RoomService.CreateRoomAsync(createDto);
        }
        else
        {
            var updateDto = new RoomUpdateDto(EditRoom.Number, EditRoom.Name, EditRoom.Has3D, EditRoom.IsWheelchairAccessible, rowCreateDtos);
            success = await RoomService.UpdateRoomAsync(SelectedRoom!.Id, updateDto);
        }

        if (success)
        {
            await LoadRooms();
            CloseModal();
        }
    }

    private async Task HandleDelete()
    {
        if (SelectedRoom == null) return;

        var success = await RoomService.DeleteRoomAsync(SelectedRoom.Id);
        if (success)
        {
            await LoadRooms();
            ShowConfirmation = false;
            CloseModal();
        }
    }
}
