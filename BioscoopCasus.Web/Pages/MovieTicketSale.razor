@page "/movies/{MovieId}/ticketsale/{ShowtimeId}"
@page "/movies/{MovieId}/ticketsale/{ShowtimeId}/{ReturnUrl}"
@using System.Globalization

@inject NavigationManager NavigationManager
@inject MovieInformationService MovieInformationService
@inject TicketPricingService TicketPricingConfigService

<div class="movies-page">
<div class="movie-details-wrapper">
    <button class="return-button" @onclick="GoBackToOverview">
        <span class="return-button-icon">←</span>
        <span>Terug naar films</span>
    </button>
<h1>Tickets kopen</h1>

@if (_isLoading)
{
    <p class="empty-message">Loading...</p>
}
else if (_movieInfo == null)
{
    <p class="empty-message">Film informatie kon niet worden geladen.</p>
}
else
{
    <div class="ticket-card">

        <div class="movie-info">
            <h2>@_movieInfo.Title</h2>
            <p>@_showtime.ToString("dddd dd MMMM HH:mm")</p>
        </div>

        <div class="ticket-section">
            <div class="ticket-row">
                <span>Normaal</span>
                <input type="number" min="0" @bind="_normalTickets" @bind:event="oninput" />
                <span>@((_normalTickets * NormalPrice).ToString("C", new CultureInfo("nl-NL")))</span>
            </div>

            <div class="ticket-row">
                <span>Kind</span>
                <input type="number" min="0" @bind="_childTickets" @bind:event="oninput" />
                <span>@((_childTickets * ChildPrice).ToString("C", new CultureInfo("nl-NL")))</span>
            </div>

            <div class="ticket-row">
                <span>Student</span>
                <input type="number" min="0" @bind="_studentTickets" @bind:event="oninput" />
                <span>@((_studentTickets * StudentPrice).ToString("C", new CultureInfo("nl-NL")))</span>
            </div>

            <div class="ticket-row">
                <span>65+</span>
                <input type="number" min="0" @bind="_seniorTickets" @bind:event="oninput" />
                <span>@((_seniorTickets * SeniorPrice).ToString("C", new CultureInfo("nl-NL")))</span>
            </div>
        </div>

        <div class="voucher-section">
            <label>
                <input type="checkbox" @bind="_useVoucher"/>
                Nationale Bioscoopbon gebruiken
            </label>

            @if (_useVoucher)
            {
                <input class="voucher-input" placeholder="Voucher code"/>
            }
        </div>

        <div class="total-section">
            <span>Totaal</span>
            <strong>@TotalPrice.ToString("C", new CultureInfo("nl-NL"))</strong>
        </div>

        <button class="buy-button" @onclick="BuyTickets">
            Doorgaan naar betaling
        </button>

    </div>
}

</div>
</div>

@code {

[Parameter] 
    public string MovieId { get; set; } = string.Empty;
[Parameter]
    public string ShowtimeId { get; set; }  = string.Empty;
[Parameter]
    public string? ReturnUrl { get; set; }

private bool _isLoading = true;

private MovieResponseDto? _movieInfo;
private DateTime _showtime;

private int _normalTickets;
private int _childTickets;
private int _studentTickets;
private int _seniorTickets;

private bool _useVoucher;

private int _movieDurationMinutes;
// TODO: Pass parameter for a movie being 3D
private const bool IsThreeD = false; // There is no property being passed for 3D yet, so it's always false


/*
 LOAD MOVIE DATA
*/

protected override async Task OnInitializedAsync()
{
    await LoadMovieInformation();
}

private void GoBackToOverview()
{
    NavigationManager.NavigateTo(ReturnUrl ?? "/movies");
}

private async Task LoadMovieInformation()
{
    try
    {
        var movieTask = MovieInformationService.GetMovieInformationAsync(MovieId);
        var timeoutTask = Task.Delay(5000);

        var completedTask = await Task.WhenAny(movieTask, timeoutTask);

        if (completedTask == movieTask)
        {
            _movieInfo = await movieTask;

            if (_movieInfo != null)
            {
                _movieDurationMinutes = _movieInfo.DurationMinutes;

                var showtime = _movieInfo.Showtimes?
                    .FirstOrDefault(s => s.Id.ToString() == ShowtimeId);

                if (showtime != null)
                    _showtime = showtime.StartTime;
            }
        }
    }
    catch
    {
        _movieInfo = null;
    }

    _isLoading = false;
}


/*
 BASE PRICE FROM CONFIG SERVICE
*/

private decimal BaseTicketPrice
{
    get
    {
        var price = TicketPricingConfigService
            .GetBasePrice(_movieDurationMinutes);

        // Always false, no parameter is being passed for 3D yet.
        if (IsThreeD)
            price += TicketPricingConfigService.GetThreeDSurcharge();

        return price;
    }
}

private bool IsChildDiscountValid =>
    TicketPricingConfigService.IsChildDiscountValid(_showtime);

private bool IsStudentDiscountValid =>
    TicketPricingConfigService.IsStudentDiscountValid(_showtime);

private bool IsSeniorDiscountValid =>
    TicketPricingConfigService.IsSeniorDiscountValid(_showtime);

private bool IsVoucherValid =>
    TicketPricingConfigService.IsVoucherValid(_showtime);


/*
 FINAL PRICES
*/

private decimal NormalPrice => BaseTicketPrice;

private decimal ChildPrice =>
    IsChildDiscountValid
        ? BaseTicketPrice - TicketPricingConfigService.GetChildDiscount()
        : BaseTicketPrice;

private decimal StudentPrice =>
    IsStudentDiscountValid
        ? BaseTicketPrice - TicketPricingConfigService.GetStudentDiscount()
        : BaseTicketPrice;

private decimal SeniorPrice =>
    IsSeniorDiscountValid
        ? BaseTicketPrice - TicketPricingConfigService.GetSeniorDiscount()
        : BaseTicketPrice;


private decimal TotalPrice
{
    get
    {
        var total =
            _normalTickets * NormalPrice +
            _childTickets * ChildPrice +
            _studentTickets * StudentPrice +
            _seniorTickets * SeniorPrice;

        if (_useVoucher && IsVoucherValid)
        {
            total -= 10m; // voucher example
        }

        return Math.Max(total, 0);
    }
}


/*
 PURCHASE
*/

private void BuyTickets()
{
    if (TotalTickets == 0)
        return;

    if (!_useVoucher || IsVoucherValid) return;
    
    Console.WriteLine("Voucher not valid for this showtime");
    
    // TODO: call reservation API
}

private int TotalTickets =>
    _normalTickets +
    _childTickets +
    _studentTickets +
    _seniorTickets;

}

