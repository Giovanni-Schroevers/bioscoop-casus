@page "/films"
@inject MoviesOverviewService MoviesOverviewService
@using BioscoopCasus.Models.DTOs
@using BioscoopCasus.Web.Services
<div class="movies-page">
    <h1>Films</h1>

    <select class="day-select" @onchange="OnDayChanged">
        @foreach (var day in AvailableDays)
        {
            <option value="@day.ToString("yyyy-MM-dd")">@day.ToString("dddd dd MMMM")</option>
        }
    </select>

    @if (Movies == null)
    {
        <p class="empty-message">Loading...</p>
    }
    else if (!Movies.Any())
    {
        <p class="empty-message">Geen films beschikbaar voor deze dag.</p>
    }
    else
    {
        <div class="movie-grid">
            @foreach (var movie in Movies)
            {
                <div class="movie-card">
                    <img src="https://placehold.co/200x250" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h3>@movie.Title</h3>
                        <p class="movie-genres">@movie.Genres</p>
                        <p class="movie-duration">@movie.DurationMinutes minuten</p>
                        <div class="showtimes">
                            @foreach (var showtime in movie.Showtimes)
                            {
                                <span class="showtime">@showtime.StartTime.ToString("HH:mm")</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
@code
{
    private List<MoviesOverviewDto>? Movies;
    private List<DateTime> AvailableDays = [];
    private DateTime SelectedDay;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        var endOfWeek = today.AddDays(7 - (int)today.DayOfWeek);
        
        for (var d = today; d <= endOfWeek; d = d.AddDays(1))
            AvailableDays.Add(d);

        SelectedDay = today;
        await LoadMovies();
    }

    private async Task OnDayChanged(ChangeEventArgs e)
    {
        SelectedDay = DateTime.Parse(e.Value!.ToString()!);
        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        Movies = await MoviesOverviewService.GetMoviesAsync(SelectedDay);
    }
}

