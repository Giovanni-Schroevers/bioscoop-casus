@page "/movies"
@inject MoviesOverviewService MoviesOverviewService
@inject NavigationManager NavigationManager
@using BioscoopCasus.Web.Layout

<TerminalShell>
<div class="movies-page">
    <button class="return-button" @onclick="@(() => NavigationManager.NavigateTo("/"))">
        <span class="return-button-icon">←</span>
        <span>Terug naar home</span>
    </button>
    <h1>Films</h1>

    <select class="day-select" @onchange="OnDayChanged">
        @foreach (var day in _availableDays)
        {
            <option value="@day.ToString("yyyy-MM-dd")">@day.ToString("dddd dd MMMM")</option>
        }
    </select>

    @if (_movies == null)
    {
        <p class="empty-message">Loading...</p>
    }
    else if (!_movies.Any())
    {
        <p class="empty-message">Geen films beschikbaar voor deze dag.</p>
    }
    else
    {
        <div class="movie-grid">
            @foreach (var movie in _movies)
            {
                <div class="movie-card clickable-card" @onclick="@(() => OpenMovie(movie.Id))">
                    <img src="https://placehold.co/200x250" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h3>@movie.Title</h3>
                        <p class="movie-genres">@movie.Genres</p>
                        <p class="movie-duration">@movie.DurationMinutes minuten</p>
                        <p class="showtime-label">Tijden</p>
                        <div class="showtimes">
                            @foreach (var showtime in movie.Showtimes)
                            {
                                <span class="showtime"
                                      @onclick="() => OpenTicketSale(movie.Id, showtime.Id)"
                                      @onclick:stopPropagation>
                                    @showtime.StartTime.ToString("HH:mm")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>
</TerminalShell>
@code
{
    private List<MoviesOverviewDto>? _movies;
    private List<DateTime> _availableDays = [];
    private DateTime _selectedDay;

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        var endDate = today.AddDays(7);

        for (var d = today; d <= endDate; d = d.AddDays(1))
            _availableDays.Add(d);

        _selectedDay = today;
        await LoadMovies();
    }

    private async Task OnDayChanged(ChangeEventArgs e)
    {
        _selectedDay = DateTime.Parse(e.Value!.ToString()!);
        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        _movies = await MoviesOverviewService.GetMoviesAsync(_selectedDay);
    }
    
    private void OpenMovie(int movieId)
    {
        NavigationManager.NavigateTo($"/movies/{movieId}");
    }
    
    private void OpenTicketSale(int movieId, int showtimeId)
    {
        NavigationManager.NavigateTo($"/movies/{movieId.ToString()}/ticketsale/{showtimeId.ToString()}");
    }
}

