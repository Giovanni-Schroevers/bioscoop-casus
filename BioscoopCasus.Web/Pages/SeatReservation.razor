@page "/seat-reservation"
@inject SeatSelectionService SeatSelectionService
@inject NavigationManager NavigationManager

<PageTitle>Stoel Reserveren</PageTitle>

<div class="seat-reservation-page">
    <h1>Stoel Reserveren</h1>

    @if (Movies == null)
    {
        <p class="loading">Films laden...</p>
    }
    else if (!Movies.Any())
    {
        <p class="empty-message">Geen films beschikbaar.</p>
    }
    else
    {
        <div class="movie-grid">
            @foreach (var movie in Movies)
            {
                <div class="movie-card clickable-card" @onclick="() => SelectMovie(movie)">
                    <img src="https://placehold.co/200x250" alt="@movie.Title" />
                    <div class="movie-card-info">
                        <h3>@movie.Title</h3>
                        <p class="movie-description">@movie.Description</p>
                    </div>
                </div>
            }
        </div>
    }

    @if (ConfirmationResult != null)
    {
        <div class="success-message">
            <h4>Succes!</h4>
            <p>@ConfirmationResult.Message</p>
            <p>Reservering ID: @ConfirmationResult.ReservationId</p>
        </div>
    }
</div>

<TerminalModal Visible="ShowShowtimeModal" Title="Kies een tijd" OnClose="CloseShowtimeModal">
    <ChildContent>
        @if (Showtimes != null && Showtimes.Any())
        {
            <div class="showtime-list">
                @foreach (var showtime in Showtimes)
                {
                    <div class="showtime-item" @onclick="() => SelectShowtime(showtime)">
                        <p>@showtime.StartTime.ToString("dd/MM/yyyy HH:mm") - Zaal @showtime.RoomId</p>
                    </div>
                }
            </div>
        }
        else
        {
            <p>Geen tijden beschikbaar.</p>
        }
    </ChildContent>
</TerminalModal>

<TerminalModal Visible="ShowGroupSizeModal" Title="Aantal personen" OnClose="CloseGroupSizeModal">
    <ChildContent>
        <div class="group-size-input">
            <label>Aantal personen:</label>
            <input type="number" @bind="GroupSize" @bind:event="oninput" min="1" max="20" />
        </div>
    </ChildContent>
    <Footer>
        <FormButton IsPrimary="true" Text="Volgende" OnClick="ConfirmGroupSize" />
    </Footer>
</TerminalModal>

<TerminalModal Visible="ShowSeatsModal" Title="Kies stoelen" OnClose="CloseSeatsModal">
    <ChildContent>
        @if (SeatSelectionResult != null)
        {
            <div class="suggestion-message" style="background: @(SeatSelectionResult.IsGroupedTogether ? "#d4edda" : "#fff3cd"); color: @(SeatSelectionResult.IsGroupedTogether ? "#155724" : "#856404");">
                <strong>@SeatSelectionResult.Message</strong>
            </div>
        }

        <!-- Cinema Screen -->
        <div class="cinema-screen">
            <div>SCHERM</div>
        </div>

        @if (AllSeats != null)
        {
            <div class="seats-grid">
                @for (int row = 1; row <= MaxRow; row++)
                {
                    <div class="row">
                        <div class="row-label">Rij @row</div>
                        <div class="seats">
                            @for (int seat = 1; seat <= MaxSeat; seat++)
                            {
                                var seatInfo = AllSeats.FirstOrDefault(s => s.Row == row && s.SeatNumber == seat);
                                var isSelected = SelectedSeatIds.Contains(seatInfo?.Id ?? 0);
                                var seatClass = GetSeatClass(seatInfo, isSelected);

                                <div @onclick="() => ToggleSeatSelection(seatInfo)"
                                     class="seat @seatClass"
                                     title="@(seatInfo != null ? $"Rij {row}, Stoel {seat}" : "Stoel niet beschikbaar")">
                                    @seat
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="legend">
                <div class="legend-item">
                    <div class="seat available"></div>
                    <span>Vrij</span>
                </div>
                <div class="legend-item">
                    <div class="seat occupied"></div>
                    <span>Bezet</span>
                </div>
                <div class="legend-item">
                    <div class="seat selected"></div>
                    <span>Geselecteerd</span>
                </div>
            </div>
        }
    </ChildContent>
    <Footer>
        <FormButton IsPrimary="true" Text="@ConfirmButtonText" OnClick="ConfirmReservation" Disabled="!SelectedSeatIds.Any()" />
    </Footer>
</TerminalModal>

<style>
    .seat-reservation-page {
        background-color: #0b0e14;
        min-height: 100vh;
        padding: 3rem;
        color: #f8fafc;
    }

    h1 {
        color: #f8fafc;
        margin-bottom: 1.5rem;
    }

    .loading, .empty-message {
        color: #94a3b8;
        font-style: italic;
    }

    .movie-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1.5rem;
    }

    .movie-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
    }

    .success-message {
        background: #d4edda;
        color: #155724;
        padding: 15px;
        border-radius: 5px;
        margin-top: 20px;
    }

    .showtime-list {
        max-height: 300px;
        overflow-y: auto;
    }

    .showtime-item {
        padding: 10px;
        border-bottom: 1px solid #333;
        cursor: pointer;
    }

    .showtime-item:hover {
        background: rgba(255, 255, 255, 0.1);
    }

    .group-size-input {
        display: flex;
        flex-direction: column;
    }

    .group-size-input label {
        margin-bottom: 0.5rem;
    }

    .seats-grid {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-top: 10px;
    }

    .row {
        display: flex;
        align-items: center;
    }

    .row-label {
        width: 40px;
        text-align: center;
        color: #94a3b8;
        writing-mode: vertical-rl;
        text-orientation: mixed;
    }

    .seats {
        display: flex;
        justify-content: center;
        gap: 3px;
        flex: 1;
    }

    .seat {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 5px;
        cursor: pointer;
        font-size: 0.875rem;
    }

    .seat.available {
        background: #28a745;
    }

    .seat.occupied {
        background: #dc3545;
    }

    .seat.selected {
        background: #ffc107;
        border: 2px solid #e0a800;
    }

    .legend {
        display: flex;
        justify-content: space-around;
        margin-top: 1rem;
        font-size: 0.875rem;
    }

    .legend-item {
        display: flex;
        align-items: center;
    }

    .legend-item .seat {
        width: 20px;
        height: 20px;
        border-radius: 3px;
    }
</style>

@code {
    private List<MovieResponseDto>? Movies;
    private bool ShowShowtimeModal = false;
    private MovieResponseDto? SelectedMovie;
    private List<ShowtimeResponseDto>? Showtimes;
    private bool ShowGroupSizeModal = false;
    private ShowtimeResponseDto? SelectedShowtime;
    private int GroupSize = 1;
    private bool ShowSeatsModal = false;
    private List<SeatInfoDto>? AllSeats;
    private SeatSelectionResponseDto? SeatSelectionResult;
    private HashSet<int> SelectedSeatIds = new();
    private int MaxRow = 0;
    private int MaxSeat = 0;
    private ReservationConfirmResponseDto? ConfirmationResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadMovies();
    }

    private async Task LoadMovies()
    {
        Movies = await SeatSelectionService.GetMoviesAsync();
        StateHasChanged();
    }

    private void SelectMovie(MovieResponseDto movie)
    {
        SelectedMovie = movie;
        ShowShowtimeModal = true;
        _ = LoadShowtimes();
    }

    private async Task LoadShowtimes()
    {
        if (SelectedMovie != null)
        {
            Showtimes = await SeatSelectionService.GetShowtimesForMovieAsync(SelectedMovie.Id);
        }
        StateHasChanged();
    }

    private void SelectShowtime(ShowtimeResponseDto showtime)
    {
        SelectedShowtime = showtime;
        ShowShowtimeModal = false;
        ShowGroupSizeModal = true;
    }

    private void CloseShowtimeModal()
    {
        ShowShowtimeModal = false;
    }

    private void ConfirmGroupSize()
    {
        ShowGroupSizeModal = false;
        ShowSeatsModal = true;
        _ = LoadSeatsAndSuggestions();
    }

    private void CloseGroupSizeModal()
    {
        ShowGroupSizeModal = false;
    }

    private async Task LoadSeatsAndSuggestions()
    {
        if (SelectedShowtime == null) return;

        AllSeats = await SeatSelectionService.GetAvailableSeatsAsync(SelectedShowtime.Id);
        
        SeatSelectionResult = await SeatSelectionService.SuggestSeatsAsync(SelectedShowtime.Id, GroupSize);

        if (SeatSelectionResult != null)
        {
            SelectedSeatIds = new HashSet<int>(SeatSelectionResult.SuggestedSeats.Select(s => s.Id));
        }

        if (AllSeats != null && AllSeats.Any())
        {
            MaxRow = AllSeats.Max(s => s.Row);
            MaxSeat = AllSeats.Max(s => s.SeatNumber);
        }

        StateHasChanged();
    }

    private void ToggleSeatSelection(SeatInfoDto? seat)
    {
        if (seat == null || !seat.IsAvailable) return;

        if (SelectedSeatIds.Contains(seat.Id))
        {
            SelectedSeatIds.Remove(seat.Id);
        }
        else
        {
            SelectedSeatIds.Add(seat.Id);
        }

        StateHasChanged();
    }

    private async Task ConfirmReservation()
    {
        if (SelectedShowtime == null || !SelectedSeatIds.Any()) return;

        ConfirmationResult = await SeatSelectionService.ConfirmReservationAsync(
            SelectedShowtime.Id,
            SelectedSeatIds.ToList());

        ShowSeatsModal = false;
        StateHasChanged();
    }

    private void CloseSeatsModal()
    {
        ShowSeatsModal = false;
    }

    private string GetSeatClass(SeatInfoDto? seat, bool isSelected)
    {
        if (seat == null) return "";

        if (isSelected) return "selected";

        return seat.IsAvailable ? "available" : "occupied";
    }

    private string ConfirmButtonText => $"Bevestig Reservering ({SelectedSeatIds.Count} stoelen)";
}
