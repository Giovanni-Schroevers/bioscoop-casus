@page "/seat-reservation"
@inject SeatSelectionService SeatSelectionService

<h1>Seat Reservation</h1>

@if (Movies == null)
{
    <p>Loading movies...</p>
}
else
{
    <div class="movie-grid">
        @foreach (var movie in Movies)
        {
            <div class="movie-card" @onclick="() => SelectMovie(movie)">
                <img src="https://placehold.co/200x250" />
                <h3>@movie.Title</h3>
            </div>
        }
    </div>
}

@if (ConfirmationResult != null)
{
    <div class="success">
        Reservation successful! ID: @ConfirmationResult.ReservationId
    </div>
}

<!-- SHOWTIME POPUP -->

@if (ShowShowtimeModal)
{
    <div class="modal-overlay">
        <div class="modal">

            <h2>Choose a time</h2>

            @if (Showtimes == null)
            {
                <p>Loading...</p>
            }
            else
            {
                @foreach (var showtime in Showtimes)
                {
                    <div class="showtime"
                         @onclick="() => SelectShowtime(showtime)">
                        @showtime.StartTime.ToString("dd/MM HH:mm") - Room @showtime.RoomId
                    </div>
                }
            }

            <button @onclick="CloseShowtimeModal">Close</button>

        </div>
    </div>
}

<!-- GROUP SIZE POPUP -->

@if (ShowGroupSizeModal)
{
    <div class="modal-overlay">
        <div class="modal">

            <h2>Number of people</h2>

            <input type="number" min="1" max="20" @bind="GroupSize" />

            <button @onclick="ConfirmGroupSize">Next</button>

        </div>
    </div>
}

<!-- SEAT POPUP -->

@if (ShowSeatsModal)
{
    <div class="modal-overlay">
        <div class="modal large">

            <h2>Choose seats</h2>

            @if (IsLoadingSeats)
            {
                <p>Loading seats...</p>
            }
            else if (AllSeats == null || !AllSeats.Any())
            {
                <p>No seats available for this showtime.</p>
            }
            else
            {
                <div class="screen">SCREEN</div>

                <div class="seats-grid">

                    @for (int row = 1; row <= MaxRow; row++)
                    {
                        <div class="row">

                            <div class="row-label">Row @row</div>

                            @for (int seat = 1; seat <= MaxSeat; seat++)
                            {
                                var seatInfo = AllSeats.FirstOrDefault(
                                s => s.Row == row && s.SeatNumber == seat);

                                var isSelected =
                                SelectedSeatIds.Contains(seatInfo?.Id ?? 0);

                                var seatClass = GetSeatClass(seatInfo, isSelected);

                                <div class="seat @seatClass"
                                     @onclick="() => ToggleSeatSelection(seatInfo)">
                                    @seat
                                </div>
                            }

                        </div>
                    }

                </div>
            }

            <button disabled="@(!SelectedSeatIds.Any())"
                    @onclick="ConfirmReservation">

                Confirm (@SelectedSeatIds.Count)

            </button>

        </div>
    </div>
}

<style>

body{
background:#0b0e14;
color:white;
}

.movie-grid{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:20px;
margin-top:20px;
}

.movie-card{
background:#1a1f2b;
padding:10px;
border-radius:10px;
cursor:pointer;
text-align:center;
}

.movie-card:hover{
background:#2b3242;
}

.modal-overlay{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.8);
display:flex;
align-items:center;
justify-content:center;
z-index:999;
}

.modal{
background:#1e2533;
padding:30px;
border-radius:10px;
min-width:400px;
}

.modal.large{
width:800px;
}

.showtime{
padding:10px;
border-bottom:1px solid #444;
cursor:pointer;
}

.showtime:hover{
background:#2b3242;
}

.screen{
text-align:center;
margin-bottom:20px;
padding:10px;
background:#333;
}

.seats-grid{
display:flex;
flex-direction:column;
gap:10px;
}

.row{
display:flex;
gap:5px;
align-items:center;
}

.row-label{
width:60px;
}

.seat{
width:35px;
height:35px;
display:flex;
align-items:center;
justify-content:center;
border-radius:5px;
cursor:pointer;
}

.available{
background:#28a745;
}

.occupied{
background:#dc3545;
}

.selected{
background:#ffc107;
}

.success{
margin-top:20px;
background:#28a745;
padding:15px;
}

</style>

@code {

List<MovieResponseDto>? Movies;

bool ShowShowtimeModal;
bool ShowGroupSizeModal;
bool ShowSeatsModal;
bool IsLoadingSeats;

MovieResponseDto? SelectedMovie;
ShowtimeResponseDto? SelectedShowtime;

List<ShowtimeResponseDto>? Showtimes;
List<SeatInfoDto>? AllSeats;

SeatSelectionResponseDto? SeatSelectionResult;

HashSet<int> SelectedSeatIds = new();

ReservationConfirmResponseDto? ConfirmationResult;

int GroupSize = 1;

int MaxRow;
int MaxSeat;


protected override async Task OnInitializedAsync()
{
    Movies = await SeatSelectionService.GetMoviesAsync();
}

async Task SelectMovie(MovieResponseDto movie)
{
    SelectedMovie = movie;

    ShowShowtimeModal = true;

    Showtimes =
    await SeatSelectionService.GetShowtimesForMovieAsync(movie.Id);
}

void CloseShowtimeModal()
{
    ShowShowtimeModal = false;
}

void SelectShowtime(ShowtimeResponseDto showtime)
{
    SelectedShowtime = showtime;

    ShowShowtimeModal = false;

    ShowGroupSizeModal = true;
}

async Task ConfirmGroupSize()
{
    // Show the seats modal immediately
    ShowGroupSizeModal = false;
    ShowSeatsModal = true;
    
    // Load seats in background
    await LoadSeats();
}

async Task LoadSeats()
{
    if (SelectedShowtime == null) return;

    IsLoadingSeats = true;
    StateHasChanged();

    try
    {
        AllSeats =
        await SeatSelectionService.GetAvailableSeatsAsync(SelectedShowtime.Id);

        if (AllSeats != null && AllSeats.Any())
        {
            SeatSelectionResult =
            await SeatSelectionService.SuggestSeatsAsync(SelectedShowtime.Id, GroupSize);

            if (SeatSelectionResult != null)
            {
                SelectedSeatIds =
                new HashSet<int>(SeatSelectionResult.SuggestedSeats.Select(x => x.Id));
            }

            MaxRow = AllSeats.Max(x => x.Row);
            MaxSeat = AllSeats.Max(x => x.SeatNumber);
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine($"Error loading seats: {ex.Message}");
        AllSeats = null;
    }
    finally
    {
        IsLoadingSeats = false;
        StateHasChanged();
    }
}

void ToggleSeatSelection(SeatInfoDto? seat)
{
    if (seat == null || !seat.IsAvailable) return;

    if (SelectedSeatIds.Contains(seat.Id))
        SelectedSeatIds.Remove(seat.Id);
    else
        SelectedSeatIds.Add(seat.Id);
}

async Task ConfirmReservation()
{
    if (SelectedShowtime == null) return;

    ConfirmationResult =
    await SeatSelectionService.ConfirmReservationAsync(
        SelectedShowtime.Id,
        SelectedSeatIds.ToList());

    ShowSeatsModal = false;
}

string GetSeatClass(SeatInfoDto? seat, bool selected)
{
    if (seat == null) return "";

    if (selected) return "selected";

    return seat.IsAvailable ? "available" : "occupied";
}

}