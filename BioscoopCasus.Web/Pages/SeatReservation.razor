@page "/seat-reservation"
@page "/seat-reservation/{MovieId}/{ShowtimeId}/{TotalTickets:int}/{TotalPriceCents:int}"
@inject SeatSelectionService SeatSelectionService
@inject NavigationManager NavigationManager
@inject IStringLocalizer<SharedResource> L

<h1>@L["SeatSelectionTitle"]</h1>

@* Only show movie grid when navigated to standalone (no params passed) *@
@if (!_cameFromTicketSale)
{
@if (Movies == null)
{
<p>@L["LoadingMovies"]</p>
}
else
{
<div class="movie-grid">
    @foreach (var movie in Movies)
    {
    <div class="movie-card" @onclick="() => SelectMovie(movie)">
        <img src="https://placehold.co/200x250" />
        <h3>@movie.Title</h3>
    </div>
    }
</div>
}
}

@if (ConfirmationResult != null)
{
<div class="success">
    @L["ReservationSuccess", ConfirmationResult.ReservationId]
</div>
}

<!-- SHOWTIME POPUP (only in standalone mode) -->

@if (ShowShowtimeModal)
{
<div class="modal-overlay">
    <div class="modal">

        <h2>@L["ChooseTime"]</h2>

        @if (Showtimes == null)
        {
        <p>@L["Loading"]</p>
        }
        else
        {
        @foreach (var showtime in Showtimes)
        {
        <div class="showtime"
             @onclick="() => SelectShowtime(showtime)">
            @showtime.StartTime.ToString("dd/MM HH:mm") - @L["RoomNumber", showtime.RoomId]
        </div>
        }
        }

        <button @onclick="CloseShowtimeModal">@L["Close"]</button>

    </div>
</div>
}

<!-- GROUP SIZE POPUP -->

@if (ShowGroupSizeModal)
{
<div class="modal-overlay">
    <div class="modal">

        <h2>@L["GroupSizeTitle"]</h2>

        @if (_cameFromTicketSale)
        {
        <p class="group-size-info">
            @L["GroupSizeInfo", GroupSize]
        </p>
        }

        <input type="number" min="1" max="20" @bind="GroupSize"
               disabled="@_cameFromTicketSale" />

        <button @onclick="ConfirmGroupSize">@L["Continue"]</button>

    </div>
</div>
}

<!-- SEAT POPUP -->

@if (ShowSeatsModal)
{
<div class="modal-overlay">
    <div class="modal large">

        <h2>@L["ChooseSeatsTitle"]</h2>
        <p class="seats-subtitle">
            @L["SelectSeatsCount", GroupSize]
            @if (_selectedMovieTitle != null)
            {
            <span> @L["ForMovie", _selectedMovieTitle]</span>
            }
            @if (_selectedShowtimeDisplay != null)
            {
            <span> - @_selectedShowtimeDisplay</span>
            }
        </p>

        @if (IsLoadingSeats)
        {
        <p>@L["SeatsLoading"]</p>
        }
        else if (AllSeats == null || !AllSeats.Any())
        {
        <p>@L["NoSeatsAvailableForShowtime"]</p>
        }
        else
        {
        <div class="screen">@L["ScreenLabel"]</div>

        <div class="seats-legend">
            <span class="legend-item"><span class="dot available"></span> @L["LegendAvailable"]</span>
            <span class="legend-item"><span class="dot occupied"></span> @L["LegendOccupied"]</span>
            <span class="legend-item"><span class="dot selected"></span> @L["LegendSelected"]</span>
        </div>

        <div class="seats-grid">

            @for (int row = 1; row <= MaxRow; row++)
            {
            <div class="row">

                <div class="row-label">@L["RowLabel", row]</div>

                @for (int seat = 1; seat <= MaxSeat; seat++)
                {
                var seatInfo = AllSeats.FirstOrDefault(
                s => s.Row == row && s.SeatNumber == seat);

                var isSelected =
                SelectedSeatIds.Contains(seatInfo?.Id ?? 0);

                var seatClass = GetSeatClass(seatInfo, isSelected);

                <div class="seat @seatClass"
                     title="@L["SeatTitle", row, seat]"
                     @onclick="() => ToggleSeatSelection(seatInfo)">
                    @seat
                </div>
                }

            </div>
            }

        </div>

        @if (_seatSelectionError != null)
        {
        <p class="seat-error">@_seatSelectionError</p>
        }
        }

        <div class="modal-actions">
            <button class="cancel-button" @onclick="() => ShowSeatsModal = false">
                @L["Cancel"]
            </button>
            <button class="confirm-button"
                    disabled="@(SelectedSeatIds.Count != GroupSize)"
                    @onclick="ConfirmReservation">
                @L["ConfirmSeatCount", SelectedSeatIds.Count, GroupSize]
            </button>
        </div>

    </div>
</div>
}

<style>

    body{
        background:#0b0e14;
        color:white;
    }

    .movie-grid{
        display:grid;
        grid-template-columns:repeat(5,1fr);
        gap:20px;
        margin-top:20px;
    }

    .movie-card{
        background:#1a1f2b;
        padding:10px;
        border-radius:10px;
        cursor:pointer;
        text-align:center;
    }

    .movie-card:hover{
        background:#2b3242;
    }

    .modal-overlay{
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.8);
        display:flex;
        align-items:center;
        justify-content:center;
        z-index:999;
    }

    .modal{
        background:#1e2533;
        padding:30px;
        border-radius:10px;
        min-width:400px;
    }

    .modal.large{
        width:800px;
        max-height:90vh;
        overflow-y:auto;
    }

    .showtime{
        padding:10px;
        border-bottom:1px solid #444;
        cursor:pointer;
    }

    .showtime:hover{
        background:#2b3242;
    }

    .screen{
        text-align:center;
        margin-bottom:16px;
        padding:10px;
        background:#333;
        border-radius:4px;
        letter-spacing:4px;
        font-size:.85rem;
        color:#aaa;
    }

    .seats-subtitle{
        margin-bottom:12px;
        font-size:.95rem;
        color:#ccc;
    }

    .seats-legend{
        display:flex;
        gap:20px;
        margin-bottom:16px;
        font-size:.85rem;
    }

    .legend-item{
        display:flex;
        align-items:center;
        gap:6px;
    }

    .dot{
        width:14px;
        height:14px;
        border-radius:3px;
        display:inline-block;
    }

    .seats-grid{
        display:flex;
        flex-direction:column;
        gap:10px;
    }

    .row{
        display:flex;
        gap:5px;
        align-items:center;
    }

    .row-label{
        width:60px;
        font-size:.8rem;
        color:#aaa;
    }

    .seat{
        width:35px;
        height:35px;
        display:flex;
        align-items:center;
        justify-content:center;
        border-radius:5px;
        cursor:pointer;
        font-size:.8rem;
        transition:opacity .15s;
    }

    .seat:hover{
        opacity:.8;
    }

    .available{
        background:#28a745;
    }

    .occupied{
        background:#dc3545;
        cursor:not-allowed;
    }

    .selected{
        background:#ffc107;
        color:#000;
    }

    .seat-error{
        color:#ff6b6b;
        margin-top:10px;
        font-size:.9rem;
    }

    .group-size-info{
        margin-bottom:12px;
        color:#ccc;
    }

    .modal-actions{
        display:flex;
        gap:12px;
        margin-top:20px;
        justify-content:flex-end;
    }

    .cancel-button{
        background:#444;
        color:white;
        border:none;
        padding:10px 20px;
        border-radius:6px;
        cursor:pointer;
    }

    .confirm-button{
        background:#e50914;
        color:white;
        border:none;
        padding:10px 20px;
        border-radius:6px;
        cursor:pointer;
        font-weight:bold;
    }

    .confirm-button:disabled{
        opacity:.5;
        cursor:not-allowed;
    }

    .success{
        margin-top:20px;
        background:#28a745;
        padding:15px;
        border-radius:6px;
    }

</style>

@code {

// Optional route parameters (set when navigating from MovieTicketSale)
[Parameter] public string? MovieId { get; set; }
[Parameter] public string? ShowtimeId { get; set; }
[Parameter] public int TotalTickets { get; set; }
[Parameter] public int TotalPriceCents { get; set; }

List<MovieResponseDto>? Movies;

bool ShowShowtimeModal;
bool ShowGroupSizeModal;
bool ShowSeatsModal;
bool IsLoadingSeats;

MovieResponseDto? SelectedMovie;
ShowtimeResponseDto? SelectedShowtime;

List<ShowtimeResponseDto>? Showtimes;
List<SeatInfoDto>? AllSeats;

SeatSelectionResponseDto? SeatSelectionResult;

HashSet<int> SelectedSeatIds = new();

ReservationConfirmResponseDto? ConfirmationResult;

int GroupSize = 1;

int MaxRow;
int MaxSeat;

string? _selectedMovieTitle;
string? _selectedShowtimeDisplay;
string? _seatSelectionError;

// True when navigated here from the ticket sale flow
bool _cameFromTicketSale => !string.IsNullOrEmpty(MovieId) && !string.IsNullOrEmpty(ShowtimeId);


protected override async Task OnInitializedAsync()
{
if (_cameFromTicketSale)
{
// Came from ticket sale: load showtimes for the given movie+showtime
// so we can resolve the showtime object, then open group size modal.
await LoadShowtimeFromParams();
}
else
{
// Standalone mode: show movie grid
Movies = await SeatSelectionService.GetMoviesAsync();
}
}

// Resolve the ShowtimeResponseDto from the URL params
async Task LoadShowtimeFromParams()
{
try
{ if (!int.TryParse(MovieId, out var movieIdInt)) return; 
    var showtimes = await SeatSelectionService.GetShowtimesForMovieAsync(movieIdInt);
if (showtimes != null)
{
SelectedShowtime = showtimes.FirstOrDefault(
s => s.Id.ToString() == ShowtimeId);

if (SelectedShowtime != null)
_selectedShowtimeDisplay = SelectedShowtime.StartTime.ToString("dddd dd MMMM HH:mm");
}

// Try to get movie title for display
var movies = await SeatSelectionService.GetMoviesAsync();
SelectedMovie = movies?.FirstOrDefault(m => m.Id.ToString() == MovieId);
_selectedMovieTitle = SelectedMovie?.Title;
}
catch (Exception ex)
{
Console.WriteLine($"Error loading showtime from params: {ex.Message}");
}

// Pre-fill group size from ticket count and open modal
GroupSize = TotalTickets > 0 ? TotalTickets : 1;
ShowGroupSizeModal = true;
}


// Standalone flow

async Task SelectMovie(MovieResponseDto movie)
{
SelectedMovie = movie;
_selectedMovieTitle = movie.Title;
ShowShowtimeModal = true;
Showtimes = await SeatSelectionService.GetShowtimesForMovieAsync(movie.Id);
}

void CloseShowtimeModal()
{
ShowShowtimeModal = false;
}

void SelectShowtime(ShowtimeResponseDto showtime)
{
SelectedShowtime = showtime;
_selectedShowtimeDisplay = showtime.StartTime.ToString("dddd dd MMMM HH:mm");
ShowShowtimeModal = false;
ShowGroupSizeModal = true;
}


// Shared flow

async Task ConfirmGroupSize()
{
ShowGroupSizeModal = false;
ShowSeatsModal = true;
SelectedSeatIds.Clear();
_seatSelectionError = null;
await LoadSeats();
}

async Task LoadSeats()
{
if (SelectedShowtime == null) return;

IsLoadingSeats = true;
StateHasChanged();

try
{
AllSeats =
await SeatSelectionService.GetAvailableSeatsAsync(SelectedShowtime.Id);

if (AllSeats != null && AllSeats.Any())
{
SeatSelectionResult =
await SeatSelectionService.SuggestSeatsAsync(SelectedShowtime.Id, GroupSize);

if (SeatSelectionResult != null)
{
SelectedSeatIds =
new HashSet<int>(SeatSelectionResult.SuggestedSeats.Select(x => x.Id));
}

MaxRow = AllSeats.Max(x => x.Row);
MaxSeat = AllSeats.Max(x => x.SeatNumber);
}
}
catch (Exception ex)
{
Console.WriteLine($"Error loading seats: {ex.Message}");
AllSeats = null;
}
finally
{
IsLoadingSeats = false;
StateHasChanged();
}
}

void ToggleSeatSelection(SeatInfoDto? seat)
{
if (seat == null || !seat.IsAvailable) return;

_seatSelectionError = null;

if (SelectedSeatIds.Contains(seat.Id))
{
SelectedSeatIds.Remove(seat.Id);
}
else
{
if (SelectedSeatIds.Count >= GroupSize)
{
_seatSelectionError = L["MaxSeatsError", GroupSize];
return;
}
SelectedSeatIds.Add(seat.Id);
}
}

async Task ConfirmReservation()
{
if (SelectedShowtime == null) return;

ConfirmationResult =
await SeatSelectionService.ConfirmReservationAsync(
SelectedShowtime.Id,
SelectedSeatIds.ToList());

ShowSeatsModal = false;

// Navigate to payment page, carrying the total price (in cents)
var priceCents = _cameFromTicketSale ? TotalPriceCents : 0;
NavigationManager.NavigateTo($"/pin/{priceCents}");
}

string GetSeatClass(SeatInfoDto? seat, bool selected)
{
if (seat == null) return "";
if (selected) return "selected";
return seat.IsAvailable ? "available" : "occupied";
}

}
