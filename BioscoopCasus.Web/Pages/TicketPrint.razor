@page "/TicketPrint/{ReservationId:int}"
@inject ReservationService ReservationService
@inject QrCodeHelper QrCodeHelper

<PageTitle>Ticket</PageTitle>

@if (isLoading)
{
    // Show empty page while loading
}
else if (reservation is null)
{
    <div class="alert alert-danger mt-5" role="alert">
        Reservation not found.
    </div>
}
else
{
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h2 class="card-title mb-4 text-center">Bioscoop Ticket</h2>

                        <div class="mb-3">
                            <strong>Film:</strong> @reservation.MovieTitle
                        </div>

                        <div class="mb-3">
                            <strong>Zaal:</strong> @reservation.RoomName
                        </div>

                        <div class="mb-3">
                            <strong>Tijd:</strong> @reservation.Showtime.StartTime.ToString("dddd, dd MMMM, yyyy 'om' HH:mm")
                        </div>

                        <div class="mb-3">
                            <strong>Stoelen:</strong>
                            <ul class="mb-0">
                                @foreach (var seat in reservation.Seats)
                                {
                                    <li>Rij @seat.Row, Stoel @seat.SeatNumber</li>
                                }
                            </ul>
                        </div>

                        <div class="text-center my-4">
                            <img src="data:image/png;base64,@qrCodeImage" alt="QR Code" class="img-fluid" style="max-width: 300px;" />
                        </div>

                        <div class="text-center">
                            <p class="mb-0"><strong>Ticket Code:</strong></p>
                            <p class="font-monospace">@qrCodeText</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ReservationId { get; set; }

    private ReservationResponseDto? reservation;
    private bool isLoading = true;
    private string qrCodeText = string.Empty;
    private string qrCodeImage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        reservation = await ReservationService.GetReservationAsync(ReservationId);

        if (reservation is not null)
        {
            qrCodeText = QrCodeHelper.GetQrCodeString(reservation);
            qrCodeImage = QrCodeHelper.GetQrCodeImage(qrCodeText);
        }

        isLoading = false;
    }
}
