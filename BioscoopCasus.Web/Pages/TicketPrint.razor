@page "/TicketPrint/{ReservationId:int}"
@inject ReservationService ReservationService
@inject QrCodeHelper QrCodeHelper
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["TicketTitle"]</PageTitle>

@if (_isLoading)
{
    // Show empty page while loading
}
else if (_reservation is null)
{
    <div class="alert alert-danger mt-5" role="alert">
        @L["ReservationNotFound"]
    </div>
}
else if (_isExpired)
{
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="alert alert-warning" role="alert">
                    <h4 class="alert-heading">@L["TicketExpiredTitle"]</h4>
                    <p>@L["TicketExpiredMessage"]</p>
                    <hr>
                    <p class="mb-0">
                        <strong>@L["MovieLabel"]</strong> @_reservation.MovieTitle<br>
                        <strong>@L["StartTimeLabel"]</strong> @_reservation.Showtime.StartTime.ToString("dddd, dd MMMM, yyyy HH:mm")
                    </p>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow">
                    <div class="card-body p-4">
                        <h2 class="card-title mb-4 text-center">@L["CinemaTicketTitle"]</h2>

                        <div class="mb-3">
                            <strong>@L["MovieLabel"]</strong> @_reservation.MovieTitle
                        </div>

                        <div class="mb-3">
                            <strong>@L["RoomLabel"]</strong> @_reservation.RoomName
                        </div>

                        <div class="mb-3">
                            <strong>@L["TimeLabel"]</strong> @_reservation.Showtime.StartTime.ToString("dddd, dd MMMM, yyyy HH:mm")
                        </div>

                        <div class="mb-3">
                            <strong>@L["SeatsLabel"]</strong>
                            <ul class="mb-0">
                                @foreach (var rowGroup in _reservation.Seats.GroupBy(s => s.Row).OrderBy(g => g.Key))
                                {
                                    <li>
                                        @L["RowSeatList", rowGroup.Key, string.Join(", ", rowGroup.OrderBy(s => s.SeatNumber).Select(s => string.Format(L["SeatNumber"], s.SeatNumber)))]
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="text-center my-4">
                            <img src="data:image/png;base64,@_qrCodeImage" alt="@L["QrCodeAlt"]" class="img-fluid" style="max-width: 300px;" />
                        </div>

                        <div class="text-center">
                            <p class="mb-0"><strong>@L["TicketCodeLabel"]</strong></p>
                            <p class="font-monospace">@_qrCodeText</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ReservationId { get; set; }

    private ReservationResponseDto? _reservation;
    private bool _isLoading = true;
    private bool _isExpired;
    private string _qrCodeText = string.Empty;
    private string _qrCodeImage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _reservation = await ReservationService.GetReservationAsync(ReservationId);

        if (_reservation is null)
        {
            _isLoading = false;
            return;
        }

        if (_reservation.Showtime.StartTime <= DateTime.UtcNow)
            _isExpired = true;
        else
        {
            _qrCodeText = QrCodeHelper.GetQrCodeString(_reservation);
            _qrCodeImage = QrCodeHelper.GetQrCodeImage(_qrCodeText);
        }
        _isLoading = false;
    }
}
